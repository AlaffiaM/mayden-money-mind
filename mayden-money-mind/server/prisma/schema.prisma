// Prisma schema for Money & Mind — SQLite database
// Models: User, Subscription, Payment, Setting, Episode, ListenLog, Notification

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Registered users — both subscribers and admins
model User {
  id              Int              @id @default(autoincrement())
  fullName        String
  email           String?          @unique
  phone           String?          @unique
  passwordHash    String
  role            String           @default("user") // user | admin
  createdAt       DateTime         @default(now())
  subscriptions   Subscription[]
  payments        Payment[]
  listenLogs      ListenLog[]
  notificationReads NotificationRead[]
}

// Subscription lifecycle: pending → active → past_due → cancelled/expired
model Subscription {
  id          Int       @id @default(autoincrement())
  userId      Int
  user        User      @relation(fields: [userId], references: [id])
  plan        String    // weekly | monthly
  status      String    @default("pending") // pending | active | past_due | paused | cancelled | expired
  startDate   DateTime  @default(now())
  nextRenewal DateTime
  pausedAt    DateTime?  // set when paused to freeze the renewal timer
  autoRenew   Boolean   @default(true)
  payments    Payment[]
}

// Payment records — linked to subscriptions, tracks Paystack transactions
model Payment {
  id             Int           @id @default(autoincrement())
  userId         Int
  user           User          @relation(fields: [userId], references: [id])
  subscriptionId Int
  subscription   Subscription  @relation(fields: [subscriptionId], references: [id])
  amount         Float
  currency       String        @default("NGN")
  status         String        // pending | success | failed
  reference      String        @unique
  paidAt         DateTime?
  createdAt      DateTime      @default(now())
}

// Key-value settings store — prices, grace period, notification config, day labels
model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// Daily audio episodes — published on a weekly schedule by day type
model Episode {
  id             String      @id @default(uuid())
  title          String
  dayType        String      // monday | tuesday | wednesday | thursday | friday
  audioUrl       String?
  runTimeSeconds Int         // seconds
  showNotes      String      // rich text HTML
  publishDate    DateTime
  status         String      @default("draft") // draft | scheduled | published
  listenCount    Int         @default(0)
  createdAt      DateTime    @default(now())
  listenLogs     ListenLog[]
}

// Tracks each time a user listens to an episode
model ListenLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  episodeId String
  episode   Episode  @relation(fields: [episodeId], references: [id])
  createdAt DateTime @default(now())
}

// In-app notifications — sent by admin or system events
model Notification {
  id        Int              @id @default(autoincrement())
  title     String
  body      String
  channels  String           // comma-separated: inapp,email
  sentBy    String           @default("admin")
  sentAt    DateTime         @default(now())
  reads     NotificationRead[]
}

// Tracks which notifications each user has read — for unread badge count
model NotificationRead {
  id             Int          @id @default(autoincrement())
  userId         Int
  user           User         @relation(fields: [userId], references: [id])
  notificationId Int
  notification   Notification @relation(fields: [notificationId], references: [id])
  readAt         DateTime     @default(now())

  @@unique([userId, notificationId])
}
